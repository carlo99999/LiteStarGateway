.env
*.db
.venv/
__pycache__/
.pytest_cache/

# Coverage artifacts (pytest-cov)
.coverage
.coverage.*
htmlcov/

# graphify knowledge-graph output. Track only the curated products (graph.json,
# GRAPH_REPORT.md); ignore the regenerable cache, dated backups, machine-local
# state (.graphify_python holds an absolute path) and junk. Regenerate the
# tracked files with `graphify update .`.
graphify-out/*
!graphify-out/graph.json
!graphify-out/GRAPH_REPORT.md

# Claude Code session worktrees (machine-local, never committed)
.claude/worktrees/

.ruff_cache
.rumdl_cache
.claude-plugin
