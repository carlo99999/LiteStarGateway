# Copy to .env and adjust. Loaded automatically at startup.

# Deployment environment: "development" (default) or "production"/"prod".
# In production the app refuses to start with a missing or default JWT_SECRET.
ENVIRONMENT=development

# SQLAlchemy async connection string.
#   SQLite (dev only): sqlite+aiosqlite:///gateway.db
#   Postgres:          postgresql+asyncpg://user:pass@localhost:5432/dbname
# Production requires Postgres — the app refuses to start on SQLite there.
DATABASE_URL=sqlite+aiosqlite:///gateway.db

# Connection-pool sizing (Postgres only; ignored for SQLite).
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Shared rate-limit store for multi-replica deploys. Unset ⇒ in-memory per process.
# REDIS_URL=redis://localhost:6379
# Conservative pre-auth inference flood guard (per client IP). Keep the default
# in production unless a trusted ingress supplies an equivalent limit. A local,
# isolated load profile may raise it explicitly.
# INFERENCE_RATE_LIMIT_RPM=120

# Upstream provider call resilience: per-call timeout (seconds) and retry budget.
# REQUEST_TIMEOUT=60
# MAX_RETRIES=2

# Reject request bodies larger than this many bytes (413). Default 10 MB; raise
# it for large multimodal payloads (inline base64 images), lower it to tighten
# the DoS bound.
# MAX_BODY_SIZE=10000000

# Automatic daily key rotation (envelope keyring). Opt-in; time is UTC "HH:MM".
# When on, a lifespan task rotates the credential + JWT data keys daily.
# KEY_ROTATION_ENABLED=false
# KEY_ROTATION_TIME=03:00

# Observability lives on MLflow: per-call request traces + fleet-level ops
# metrics (requests, errors, latency, tokens, cost) logged as time series to a
# "gateway-metrics" run in the same experiment. Unset URI ⇒ observability off.
#   Classic MLflow:  https://mlflow.example.com
#   Databricks:      databricks   (auth via DATABRICKS_HOST / DATABRICKS_TOKEN;
#                    then MLFLOW_EXPERIMENT must be a workspace path, e.g. /Shared/gateway)
# MLFLOW_TRACKING_URI=
# MLFLOW_EXPERIMENT=litestar-gateway
# Seconds between metrics publishes to MLflow (0 disables the metrics run).
# MLFLOW_METRICS_INTERVAL=60

# SSO via OIDC. Requires discovery URL + client id + client secret; missing any
# ⇒ SSO disabled (routes not registered). Works with any OIDC provider
# (Google/Microsoft/Okta/Keycloak…) — point at its .well-known/openid-configuration.
# OIDC_ADMIN_GROUPS (comma-separated) maps IdP groups to platform admin. Being in
# one of these groups GRANTS admin at login; the sync is upgrade-only, so leaving
# the group does NOT revoke admin (see DEFAULT_ROLE below). Set OIDC_REDIRECT_URI
# to the public callback URL when running behind a reverse proxy; otherwise it is
# derived from the incoming request.
# OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid email profile groups
# OIDC_ADMIN_GROUPS=gateway-admins
# OIDC_REDIRECT_URI=https://gateway.example.com/sso/callback
# SSO_TEAM_MAPPING maps IdP groups to team memberships (JSON: group -> list of
# {team: <team-uuid>, role: admin|member}). On each login the user's membership
# in the mapped ("SSO-governed") teams is reconciled to their current groups;
# teams not listed here are left to manual management. role defaults to member.
# SSO_TEAM_MAPPING={"engineering": [{"team": "00000000-0000-0000-0000-000000000000", "role": "member"}]}

# DEFAULT_ROLE is the platform role a BRAND-NEW SSO user is created with at first
# login (JIT), when not matched by OIDC_ADMIN_GROUPS: "member" (default) or "admin".
# Existing users are never re-defaulted. The admin flag is UPGRADE-ONLY: groups and
# DEFAULT_ROLE only ever GRANT admin — a re-login never revokes it. Demotion is done
# explicitly by a platform admin via PATCH /users/{id}/admin.
# DEFAULT_ROLE=member

# Mark the SSO state cookie Secure (HTTPS-only). Defaults on outside local envs;
# set it explicitly to true when TLS terminates at a proxy that speaks HTTP to the
# app (the request scheme alone would otherwise look insecure).
# SESSION_COOKIE_SECURE=true

# Email of the admin user created on first startup (when the users table is empty).
ADMIN_EMAIL=admin@example.com

# Bootstrap password for the admin user. REQUIRED on first startup with an empty
# users table — the app refuses to start without it. Ignored once users exist.
# Outside local environments it must be a strong random value (>= 32 chars);
# the placeholder below is rejected at startup.
MASTER_KEY=change-me-please

# MASTER key that wraps the rotating JWT signing keys (7-day token expiry). In
# development an insecure dev default is used if unset; in production
# (ENVIRONMENT=production) it MUST be a strong random value or the app won't
# start. Keep it stable — changing it invalidates all existing login tokens.
JWT_SECRET=change-me-too

# MASTER key that wraps the rotating credential-encryption keys at rest. REQUIRED
# to create/use credentials — there is no default. Keep it stable: changing it
# makes existing credentials undecryptable. (Data keys under it rotate; this
# master does not.)
SALT_KEY=change-me-strong-random
