# Copy to .env and adjust. Loaded automatically at startup.

# SQLAlchemy async connection string.
#   SQLite (default): sqlite+aiosqlite:///api_keys.db
#   Postgres:         postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///api_keys.db

# Email of the admin user created on first startup (when the users table is empty).
ADMIN_EMAIL=admin@example.com

# Bootstrap password for the admin user. REQUIRED on first startup with an empty
# users table — the app refuses to start without it. Ignored once users exist.
MASTER_KEY=change-me-please

# Secret used to sign login JWTs (7-day expiry). MUST be a strong random value
# in production; if unset, an insecure dev default is used.
JWT_SECRET=change-me-too

# Encryption key for provider credentials at rest (litellm-style salt key).
# REQUIRED to create/use credentials — there is no default. Use a strong random
# value and keep it stable: rotating it makes existing credentials undecryptable.
SALT_KEY=change-me-strong-random
