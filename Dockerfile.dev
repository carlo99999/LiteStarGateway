# syntax=docker/dockerfile:1@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89

# Development-only images. Dependencies are baked into the image while source
# directories are bind-mounted by docker-compose.dev.yml for live reload.

# ---- Docs: build the MkDocs site the backend serves at /docs ----
# Mirrors the production Dockerfile's docs stage. The built site is baked into
# the backend image below (docs are static, so no live-reload mount is needed —
# rebuild the image to pick up doc edits, like a dependency change).
FROM ghcr.io/astral-sh/uv:python3.14-bookworm-slim@sha256:7cf77f594be8042dab6daa9fe326f90962252268b4f120a7f5dccce4d947e6c1 AS docs

ENV UV_LINK_MODE=copy
WORKDIR /app

# The dev group holds mkdocs; the project itself isn't needed to build the docs.
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# Reproduce `just docs-prepare` (the source projection mkdocs.yml's docs_dir
# points at) then build the site to /app/.mkdocs-site (mkdocs.yml site_dir).
COPY . .
RUN mkdir -p .mkdocs-docs \
    && ln -sfn ../README.md .mkdocs-docs/index.md \
    && ln -sfn ../EXAMPLES.md .mkdocs-docs/EXAMPLES.md \
    && ln -sfn ../CONTRIBUTING.md .mkdocs-docs/CONTRIBUTING.md \
    && ln -sfn ../SECURITY.md .mkdocs-docs/SECURITY.md \
    && ln -sfn ../docs .mkdocs-docs/docs \
    && ln -sfn ../issues .mkdocs-docs/issues \
    && uv run mkdocs build --strict


FROM ghcr.io/astral-sh/uv:python3.14-bookworm-slim@sha256:7cf77f594be8042dab6daa9fe326f90962252268b4f120a7f5dccce4d947e6c1 AS backend

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    PATH="/opt/venv/bin:$PATH" \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Keep dependency installation cached until the lockfile changes.
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project --no-dev

RUN useradd --create-home --uid 1000 app \
    && chown app:app /app

COPY --chown=app:app README.md LICENSE alembic.ini ./
COPY --chown=app:app src/ ./src/
COPY --chown=app:app migrations/ ./migrations/
RUN uv sync --frozen --no-dev

# The built narrative docs, served at /docs (docs_site.py looks for
# /app/.mkdocs-site). Sits beside the bind-mounted /app/src, so live reload is
# unaffected; without this the dev stack 404s /docs.
COPY --from=docs --chown=app:app /app/.mkdocs-site ./.mkdocs-site

USER app
EXPOSE 8000


FROM node:22-bookworm-slim@sha256:53ada149d435c38b14476cb57e4a7da73c15595aba79bd6971b547ceb6d018bf AS frontend

RUN npm install --global pnpm@11.6.0 \
    && mkdir -p /app/ui \
    && chown -R node:node /app

WORKDIR /app/ui
USER node

# The named node_modules volume keeps dependencies inside Linux while the UI
# source is bind-mounted from the host for Vite HMR.
COPY --chown=node:node ui/package.json ui/pnpm-lock.yaml ui/pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile --config.strict-dep-builds=false

COPY --chown=node:node ui/ ./

EXPOSE 5173


FROM ghcr.io/mlflow/mlflow:v3.14.0@sha256:967de3ca34b6a5751718e380a0a383eb0ce1a6f5b484f363bd0da7559117a5f8 AS mlflow

RUN useradd --create-home --uid 10001 mlflow \
    && mkdir -p /mlflow \
    && chown -R mlflow:mlflow /mlflow

WORKDIR /mlflow
USER mlflow
EXPOSE 5000
