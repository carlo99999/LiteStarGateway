{"nodes": [{"id": "_claude_skills_graphify_skill_graphify", "label": "Graphify Skill", "file_type": "document", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_knowledge_graph_pipeline", "label": "Knowledge Graph Build Pipeline", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 1-9", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_structural_ast_extraction", "label": "Structural AST Extraction", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part A", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Code is extracted deterministically via AST with no LLM and no API key, so a code-only corpus is free and fast; run in parallel with semantic extraction to save 5-15s on large corpora."}, {"id": "_claude_skills_graphify_skill_semantic_extraction", "label": "Semantic Extraction Subagents", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part B", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Parallel subagents (general-purpose, dispatched in one message) are mandated because reading files one-by-one is 5-10x slower; Gemini is used only if a key is already set, otherwise the host agent itself is the LLM \u2014 graphify never blocks on an API key."}, {"id": "_claude_skills_graphify_skill_extraction_cache", "label": "Semantic Extraction Cache", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B0", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cached per-file extraction results are checked before dispatching subagents so unchanged files cost zero tokens; stale cache files are deleted so Part C never merges leftovers (#1392)."}, {"id": "_claude_skills_graphify_skill_community_detection", "label": "Community Detection and Labeling", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 4-5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_god_nodes", "label": "God Nodes Analysis", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graph_health_check", "label": "Graph Health Check", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Read-only integrity gate surfacing edge collapse, dangling endpoints, and self-loops \u2014 the silent-corruption modes of incremental updates and AST/LLM id mismatches. Never aborts; warnings must be surfaced per the Honesty Rules."}, {"id": "_claude_skills_graphify_skill_honesty_rules", "label": "Honesty Rules", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Honesty Rules section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never invent an edge (use AMBIGUOUS if unsure), never skip corpus warnings, always show token cost, show raw cohesion numbers, warn before visualizing >5000 nodes \u2014 keeps the graph's audit trail honest."}, {"id": "_claude_skills_graphify_skill_fast_path_query", "label": "Fast Path: Existing Graph Query", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "What You Must Do When Invoked", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If graphify-out/graph.json exists and the request is a natural-language question, skip the entire build pipeline and run graphify query immediately \u2014 the graph is already built, so rebuilding wastes tokens and time."}, {"id": "_claude_skills_graphify_skill_shrink_guard", "label": "Graph Shrink Guard (#479)", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "to_json refuses to write when the new graph is smaller than the existing graph.json, and an empty extraction aborts before any write \u2014 so a failed extraction can never clobber a good graph, report, or analysis sidecar (#479, #1392)."}], "edges": [{"source": "_claude_skills_graphify_skill_structural_ast_extraction", "target": "_claude_skills_graphify_skill_knowledge_graph_pipeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part A", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_semantic_extraction", "target": "_claude_skills_graphify_skill_knowledge_graph_pipeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part B", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_extraction_cache", "target": "_claude_skills_graphify_skill_semantic_extraction", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B0", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_community_detection", "target": "_claude_skills_graphify_skill_knowledge_graph_pipeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 4-5", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_god_nodes", "target": "_claude_skills_graphify_skill_community_detection", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graph_health_check", "target": "_claude_skills_graphify_skill_knowledge_graph_pipeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4.5", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_honesty_rules", "target": "_claude_skills_graphify_skill_graph_health_check", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4.5", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_shrink_guard", "target": "_claude_skills_graphify_skill_knowledge_graph_pipeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify", "target": "_claude_skills_graphify_skill_knowledge_graph_pipeline", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify", "target": "_claude_skills_graphify_references_extraction_spec_subagent_prompt", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B2", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify", "target": "_claude_skills_graphify_references_update_