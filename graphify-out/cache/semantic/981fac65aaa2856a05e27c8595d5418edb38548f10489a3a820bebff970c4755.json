{"nodes": [{"id": "readme_litestar_gateway", "label": "LiteStar Gateway", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deliberately focused OpenAI-compatible gateway: curated providers via official SDKs (not reverse-engineered wire formats), security-first multi-tenant model, small auditable hexagonal codebase over sprawling feature coverage."}, {"id": "readme_inference_pipeline", "label": "Inference Data Plane Pipeline", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Authentication, spend control, and request sanitizing happen before the provider is reached; metering and tracing happen right after, off the hot path, so client latency is not impacted."}, {"id": "readme_management_plane", "label": "Multi-tenant Management Plane", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Teams never see provider secrets: models reference a credential, the gateway decrypts it per call, and usage is attributed back to team and key for billing. Credentials are platform-global by design (cross-team usage accepted trade-off)."}, {"id": "readme_rate_limiting", "label": "Rate Limiting (per key / per IP)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "/v1/* throttled per hashed API key (falls back to per-IP for anonymous tokens) to bound provider spend; /login and /signup throttled per IP to bound brute force. X-Forwarded-For is not trusted by default so a direct client cannot forge its IP."}, {"id": "readme_envelope_encryption", "label": "Envelope Encryption & Key Rotation", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Env keys (SALT_KEY, JWT_SECRET) are fixed masters wrapping a rotating keyring stored in the DB; a daily lifespan task re-encrypts credentials to a fresh data key and rotates JWT keys while keeping recent ones for the token window."}, {"id": "readme_durable_billing_outbox", "label": "Durable Billing Outbox", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Failed usage-ledger writes are dead-lettered to pending_usage_event and retried every 60s (idempotent by event id) instead of log-and-drop; synchronous success path unchanged so /usage stays immediately consistent. Caveat: outbox lives in the same Postgres, so total DB outage is not survivable."}, {"id": "readme_audit_log", "label": "Audit Log (append-only audit_event)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Privileged actions (credential/key/membership/user changes) recorded synchronously and durably to an append-only table, read via GET /audit, kept off the inference hot path."}, {"id": "readme_deployment", "label": "Deployment (container, proxy, replicas)", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "FORWARDED_ALLOW_IPS defaults to loopback so forwarded headers from untrusted peers are ignored (no IP forgery against rate limits/audit). The image ships no DATABASE_URL default because a SQLite default would give every replica its own database. MIGRATE_ON_START=false with many replicas avoids racing the same Alembic upgrade."}], "edges": [{"source": "readme_litestar_gateway", "target": "docs_ci_workflow", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_deployment_container_image", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_db_migrations_alembic", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_postgres_asyncpg_pool", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_provider_resilience_timeouts", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_param_allowlist_sanitize", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_logging_structured_logging", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_observability_mlflow_trace_sink", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_litestar_gateway", "target": "docs_usage_cost_budget", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readm