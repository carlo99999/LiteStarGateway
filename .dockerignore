# Keep the build context small and never ship local state/secrets.
.git
.github
.venv
**/__pycache__/
*.pyc
*.db
.env
.pytest_cache/
.ruff_cache/
tests/
# Locally generated MkDocs artifacts: the image builds its own in the docs stage,
# so never copy a stale local one into the build context. (docs/ source is kept:
# the docs stage needs it to build the site served at /docs.)
.mkdocs-docs/
.mkdocs-site/
# Admin UI build artifacts: the image builds its own dist in the ui stage, so
# never ship a stale local build or the local node_modules. (ui/ source is kept:
# the ui stage needs it to build the SPA served at /ui.)
ui/node_modules/
ui/dist/
