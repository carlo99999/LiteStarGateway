# Admin UI environment (Vite). Copy to `.env.local` and adjust as needed.

# Base URL for the gateway REST API used by the typed client. Leave empty to use
# same-origin, root-relative requests (the default; in dev the Vite proxy
# forwards every non-/ui path to GATEWAY_URL below).
VITE_API_BASE_URL=

# Dev-only: where `pnpm dev` proxies API calls (see vite.config.ts).
GATEWAY_URL=http://localhost:8000
